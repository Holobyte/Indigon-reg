# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ADMIN_PASSWORD: Password to access the Admin dashboard
ADMIN_PASSWORD=change-me-indigon-admin

# WARNING: Real Mailchimp keys should not be kept in public, client-side Android code
# as they can be extracted via decompilation.
# These variables serve as placeholders for reference/future integration.
MAILCHIMP_API_KEY=YOUR_MAILCHIMP_API_KEY
MAILCHIMP_SERVER_PREFIX=YOUR_MAILCHIMP_SERVER_PREFIX
MAILCHIMP_AUDIENCE_ID=YOUR_MAILCHIMP_AUDIENCE_ID

